rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 協作頁面（記帳/清單/旅記）：登入即可編輯
    match /expenses/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /twd_expenses/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /checklists/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /notes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 其他所有資料（行程等）：只有本人可寫
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.token.email == 'abc022778@gmail.com';
    }
  }
}
